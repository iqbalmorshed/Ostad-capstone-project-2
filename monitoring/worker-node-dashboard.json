        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{instance=\"10.0.1.89:9100\", device!~\"lo|veth.*|cali.*|tunl.*\"}[5m])",
            "legendFormat": "Receive — {{ device }}",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{instance=\"10.0.1.89:9100\", device!~\"lo|veth.*|cali.*|tunl.*\"}[5m])",
