{
  "dashboard": {
    "id": null,
    "uid": "worker-nodes-metrics",
    "title": "Worker Nodes - System Metrics",
    "description": "CPU, Memory, Disk, and Network metrics for Kubernetes worker nodes ip-10-0-1-89 and ip-10-0-1-144",
    "tags": ["kubernetes", "nodes", "workers"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "node",
          "label": "Worker Node",
          "type": "custom",
          "query": "10.0.1.89:9100,10.0.1.144:9100",
          "current": { "text": "All", "value": ["$__all"] },
          "options": [
            { "text": "All", "value": "$__all", "selected": true },
            { "text": "ip-10-0-1-89", "value": "10.0.1.89:9100", "selected": false },
            { "text": "ip-10-0-1-144", "value": "10.0.1.144:9100", "selected": false }
          ],
          "includeAll": true,
          "multi": true,
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage % — ip-10-0-1-89",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 15 }
          }
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=\"10.0.1.89:9100\"}[5m])) * 100)",
            "legendFormat": "CPU Usage",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "CPU Usage % — ip-10-0-1-144",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 15 }
          }
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=\"10.0.1.144:9100\"}[5m])) * 100)",
            "legendFormat": "CPU Usage",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Memory Usage % — ip-10-0-1-89",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 15 }
          }
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"10.0.1.89:9100\"} / node_memory_MemTotal_bytes{instance=\"10.0.1.89:9100\"})) * 100",
            "legendFormat": "Memory Used %",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Memory Usage % — ip-10-0-1-144",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
