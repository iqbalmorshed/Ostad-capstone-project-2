            "legendFormat": "Memory Used %",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Disk Usage % (/) — ip-10-0-1-89",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
