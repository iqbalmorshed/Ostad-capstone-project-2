          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "(1 - node_filesystem_avail_bytes{instance=\"10.0.1.89:9100\", mountpoint=\"/\", fstype!=\"tmpfs\"} / node_filesystem_size_bytes{instance=\"10.0.1.89:9100\", mountpoint=\"/\", fstype!=\"tmpfs\"}) * 100",
            "legendFormat": "Disk Used %",
            "refId": "A"
          }
        ]
