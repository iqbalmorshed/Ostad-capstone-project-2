# QuickHire Docker / local dev
# Copy to .env in this folder (Job-Task) and adjust. Optional: compose uses defaults if not set.

# MongoDB – inside Docker use host "mongo" (service name)
MONGODB_URI=mongodb://mongo:27017/quick-hire

# If you run backend outside Docker but mongo in Docker, use:
# MONGODB_URI=mongodb://localhost:27017/quick-hire

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=dev-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-different-from-access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend – API URL the browser uses (set when building/running the app)
# - Local: http://localhost:2021/api (or 3001 if you use that port)
# - Production (direct ports): use HTTPS and the public host, e.g.:
#   NEXT_PUBLIC_API_URL=https://203.190.9.174:2021/api
#   (Page and API must use same protocol to avoid "Failed to fetch" / mixed content.)
# - Same-origin (reverse proxy): leave unset so the app uses relative /api
# NEXT_PUBLIC_API_URL=http://localhost:2021/api
